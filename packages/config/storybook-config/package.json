{
  "name": "@repo/storybook-config",
  "description": "shared storybook config",
  "private": true,
  "type": "module",
  "main": "./main.ts",
  "scripts": {
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=true storybook dev -p 6006",
